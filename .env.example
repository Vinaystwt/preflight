# Public deployment identity. The public endpoint becomes frozen after OKX.AI registration.
PUBLIC_DOMAIN=api.usepreflight.xyz
PORT=3000
BUILD_SHA=replace-with-git-short-sha
LEGACY_ROUTES_ENABLED=false

# Neon Postgres connection. Keep this secret out of git.
DATABASE_URL=postgresql://REDACTED_DATABASE_URL

# X Layer payTo wallet (EIP-55/EVM address)
OPERATOR_WALLET=0x7bb9c4d6e06b9dee783eb31ff73d9345803efbd2

# Required for official OKX x402 seller settlement. Obtain at the OKX Developer Portal.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Release Gate v1 (Stage D remains undeployed until the production canary gate).
PRICE_VERIFY_RELEASE=0.10
RELEASE_PAYMENT_NETWORK=eip155:196
RELEASE_PAYMENT_ASSET=0x779ded0c9e1022225f8e0630b35a9b54be713736
# Comma-separated exact Vercel production/preview origins. Do not use a wildcard.
# Example: https://preflight.vercel.app,https://preflight-git-main-vinaystwts-projects.vercel.app
FRONTEND_ORIGINS=
REPORT_TOKEN_SECRET=REDACTED_REPORT_TOKEN_SECRET
REPORT_RETENTION_DAYS=30
FREE_DRAFT_IP_DAILY=5
FREE_DRAFT_TARGET_DAILY=10
FREE_DRAFT_GLOBAL_DAILY=60

# Self-test process only; never set either variable on the application service.
RELEASE_SELFTEST_BASE_URL=
RELEASE_SELFTEST_SIGNER=
RELEASE_SELFTEST_MANIFEST_JSON=

# Settlement listener remains available for the Release Gate paid path.
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=1 minute
PAYER_RATE_LIMIT_MAX=30
PAYER_RATE_LIMIT_WINDOW_S=60
TARGET_RATE_LIMIT_PER_HOUR=10
LOG_LEVEL=info
