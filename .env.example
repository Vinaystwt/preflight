# Public deployment identity. The public endpoint becomes frozen after OKX.AI registration.
PUBLIC_DOMAIN=api.usepreflight.xyz
PORT=3000
BUILD_SHA=replace-with-git-short-sha
LEGACY_ROUTES_ENABLED=false

# Neon Postgres connection. Keep this secret out of git.
DATABASE_URL=postgresql://REDACTED_DATABASE_URL

# X Layer payTo wallet (EIP-55/EVM address)
OPERATOR_WALLET=0x7bb9c4d6e06b9dee783eb31ff73d9345803efbd2

# Required for official OKX x402 seller settlement. Obtain at the OKX Developer Portal.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Settlement listener remains available for the Release Gate paid path.
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=1 minute
PAYER_RATE_LIMIT_MAX=30
PAYER_RATE_LIMIT_WINDOW_S=60
TARGET_RATE_LIMIT_PER_HOUR=10
LOG_LEVEL=info
