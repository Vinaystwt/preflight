# Public deployment identity. The public endpoint becomes frozen after OKX.AI registration.
PUBLIC_DOMAIN=api.usepreflight.xyz
PORT=3000
BUILD_SHA=replace-with-git-short-sha
LEGACY_ROUTES_ENABLED=false

# Postgres connection. Keep this secret out of git.
DATABASE_URL=postgresql://REDACTED_DATABASE_URL

# X Layer payTo wallet (EIP-55/EVM address)
OPERATOR_WALLET=0x7bb9c4d6e06b9dee783eb31ff73d9345803efbd2

# Required for official OKX x402 seller settlement. Obtain at the OKX Developer Portal.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Release Gate v1 (Stage D remains undeployed until the production canary gate).
PRICE_VERIFY_RELEASE=0.10
RELEASE_PAYMENT_NETWORK=eip155:196
RELEASE_PAYMENT_ASSET=0x779ded0c9e1022225f8e0630b35a9b54be713736
# Comma-separated exact Vercel production/preview origins. Do not use a wildcard.
# Example: https://preflight.vercel.app,https://preflight-git-main-vinaystwts-projects.vercel.app
FRONTEND_ORIGINS=
REPORT_TOKEN_SECRET=REDACTED_REPORT_TOKEN_SECRET
REPORT_RETENTION_DAYS=30
# Uses the existing reconciliation process; no additional worker or scheduler.
RETENTION_CLEANUP_INTERVAL_MS=86400000
FREE_DISCOVERY_CLIENT_DAILY=20
FREE_DISCOVERY_TARGET_HOURLY=10
FREE_DISCOVERY_GLOBAL_EMERGENCY_DAILY=5000
PAID_VERIFICATION_PAYER_PER_MINUTE=30
PAID_VERIFICATION_TARGET_PER_HOUR=10

# v5 marketplace evidence. The OnchainOS CLI is the authoritative authenticated
# resolver for Agent IDs; do not substitute an invented unauthenticated API.
ONCHAINOS_COMMAND=onchainos
AGENT_RESOLUTION_TTL_SECONDS=900
COHORT_ENABLED=true
COHORT_SCAN_INTERVAL_MS=21600000
COHORT_TARGET_HOURLY=10
COHORT_GLOBAL_DAILY=500
# Comma-separated IDs when marketplace enumeration is not available to this deployment.
# Seeded from the live OKX.AI marketplace because no public enumerable roster exists.
COHORT_SEED_AGENT_IDS=2013,2023,1965,3345,1891,1958,1973,1445,1719,4183,2135,1500,2161,4543,5421,5137,1409,1828,5776,5175,2012,1421,2118,4442,2327
# Protects POST /api/v1/cohort/rescan. Keep secret and set only on the API service.
COHORT_OPERATOR_TOKEN=
PASSPORT_TTL_DAYS=30
# Full paid self-check is intentionally opt-in and operator-funded.
SELF_CHECK_ENABLED=false

# Self-test process only; never set either variable on the application service.
RELEASE_SELFTEST_BASE_URL=
RELEASE_SELFTEST_SIGNER=
RELEASE_SELFTEST_MANIFEST_JSON=

# Settlement listener remains available for the Release Gate paid path.
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=1 minute
PAYER_RATE_LIMIT_MAX=30
PAYER_RATE_LIMIT_WINDOW_S=60
TARGET_RATE_LIMIT_PER_HOUR=10
LOG_LEVEL=info
