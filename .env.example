# Public deployment identity. The public endpoint becomes frozen after OKX.AI registration.
PUBLIC_DOMAIN=api.usepreflight.xyz
PORT=3000
BUILD_SHA=dev

# Neon Postgres connection. Keep this secret out of git.
DATABASE_URL=postgresql://REDACTED_DATABASE_URL

# X Layer payTo wallet (EIP-55/EVM address)
OPERATOR_WALLET=0x7bb9c4d6e06b9dee783eb31ff73d9345803efbd2

# Required for official OKX x402 seller settlement. Obtain at the OKX Developer Portal.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Dedicated funded test wallet used only by scripts/selftest.ts. Never paste this key into chat.
SELFTEST_BUYER_PRIVATE_KEY=
SELFTEST_TARGET=https://api.usepreflight.xyz/api/v1/run_preflight
SELFTEST_PROBE_TARGET=https://api.usepreflight.xyz/api/v1/run_preflight
SELFTEST_MCP_URL=https://api.usepreflight.xyz/mcp
SELFTEST_SETTLEMENT_TIMEOUT_S=120

# Dedicated service float used only for an owner-authorized deep_check outbound payment.
# Keep separate from the seller wallet and never expose this value in logs.
DEEP_CHECK_BUYER_PRIVATE_KEY=
DEEP_CHECK_TARGET_DAILY_CAP_USDT=2
DEEP_CHECK_GLOBAL_DAILY_CAP_USDT=10

# Seven-day monitor scheduler. Production registrations are clamped to at least
# 360 seconds so the 10 checks/hour/target safety cap cannot be exceeded.
MONITOR_INTERVAL_S=1800
MONITOR_DURATION_DAYS=7
MONITOR_SCHEDULER_TICK_MS=10000
MONITOR_CONCURRENCY=3
PLAYGROUND_PER_IP_DAILY=3
PLAYGROUND_GLOBAL_DAILY=200

# Per-service fixed prices in USDT. Each route is registered as its own OKX.AI service.
PRICE_CHECK_ENDPOINT=0.02
PRICE_CHECK_X402=0.05
PRICE_RUN_PREFLIGHT=0.10
PRICE_DEEP_CHECK=0.50
PRICE_WATCH=1.00
PRICE_WATCH_REPORT=0.02
PRICE_CERTIFIED=10.00

# x402 uses asynchronous settlement (syncSettle=false). All limits are env-tunable.
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=1 minute
PAYER_RATE_LIMIT_MAX=30
PAYER_RATE_LIMIT_WINDOW_S=60
TARGET_RATE_LIMIT_PER_HOUR=10
LOG_LEVEL=info

# X Layer attestation queue. The queue stays disabled (while retaining pending DB jobs)
# until both the deployer key and deployed contract address are present.
X_LAYER_RPC_URL=https://xlayerrpc.okx.com
DEPLOYER_PRIVATE_KEY=
ATTESTATION_CONTRACT_ADDRESS=
ATTESTATION_POLL_INTERVAL_MS=5000
